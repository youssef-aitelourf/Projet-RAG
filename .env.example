# --- Provider (ollama_cloud | ollama_local | openai) ---
RAG_PROVIDER=ollama_cloud

# --- Ollama Cloud (default) ---
# Get your key at https://ollama.com/settings/keys
OLLAMA_API_KEY=your_key_here
RAG_MODEL=gpt-oss:120b
OLLAMA_BASE_URL=https://ollama.com/v1

# --- Ollama local ---
# RAG_PROVIDER=ollama_local
# RAG_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- OpenAI ---
# RAG_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# RAG_MODEL=gpt-4o-mini

# Smaller/cheaper model for benchmark judge metrics (optional)
EVAL_MODEL=

# Compression experiment: extractive | llm
COMPRESSION_MODE=extractive
