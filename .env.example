# --- Provider: anthropic | ollama_cloud | ollama_local | openai ---
RAG_PROVIDER=anthropic

# --- Anthropic (recommended with Docker) ---
ANTHROPIC_API_KEY=your_key_here
RAG_MODEL=claude-sonnet-4-20250514

# --- Ollama Cloud ---
# RAG_PROVIDER=ollama_cloud
# OLLAMA_API_KEY=your_key_here
# RAG_MODEL=gpt-oss:120b
# OLLAMA_BASE_URL=https://ollama.com/v1

# --- Ollama local ---
# RAG_PROVIDER=ollama_local
# RAG_MODEL=llama3.2
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# --- OpenAI ---
# RAG_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# RAG_MODEL=gpt-4o-mini

# Optional: cheaper model for benchmark judge metrics
EVAL_MODEL=

# Compression: extractive | llm
COMPRESSION_MODE=extractive
